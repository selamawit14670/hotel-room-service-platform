datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  KITCHEN
  WAITER
  SUPERVISOR
  ADMIN
}

enum StaffStatus {
  ONDUTY
  BREAK
  OFFLINE
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  DELIVERING
  COMPLETED
  CANCELLED
}

enum DeliveryStatus {
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  FAILED
}

model User {
  id        String      @id @default(uuid()) @db.Uuid
  name      String      @db.VarChar(100)
  email     String      @unique @db.VarChar(255)
  phone     String?     @db.VarChar(20)
  password  String      @db.VarChar(255)
  role      Role
  status    StaffStatus @default(OFFLINE)
  createdAt DateTime    @default(now()) @db.Timestamptz(6)

  // Relationships
  deliveries    Delivery[]
  notifications Notification[]

  @@index([role])
  @@index([status])
  @@map("users")
}

model Guest {
  id          String   @id @default(uuid()) @db.Uuid
  roomNumber  String   @db.VarChar(20)
  guestName   String   @db.VarChar(100)
  phoneNumber String?  @db.VarChar(20)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  // Relationships
  orders Order[]

  @@index([roomNumber])
  @@map("guests")
}

model MenuCategory {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique @db.VarChar(100)

  // Relationships
  items MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id              String   @id @default(uuid()) @db.Uuid
  categoryId      String   @db.Uuid
  name            String   @db.VarChar(100)
  description     String   @db.Text
  image           String?  @db.VarChar(512)
  preparationTime Int      @default(15) // In minutes
  price           Decimal  @db.Decimal(10, 2)
  available       Boolean  @default(true)

  // Relationships
  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]

  @@index([categoryId])
  @@map("menu_items")
}

model Order {
  id           String      @id @default(uuid()) @db.Uuid
  orderNumber  Int         @unique @default(autoincrement())
  guestId      String      @db.Uuid
  roomNumber   String      @db.VarChar(20)
  totalAmount  Decimal     @db.Decimal(10, 2)
  status       OrderStatus @default(PENDING)
  createdAt    DateTime    @default(now()) @db.Timestamptz(6)

  // Relationships
  guest      Guest       @relation(fields: [guestId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]
  delivery   Delivery?

  @@index([guestId])
  @@index([roomNumber])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @db.Uuid
  menuItemId String   @db.Uuid
  quantity   Int
  price      Decimal  @db.Decimal(10, 2) // Locked-in price at point of ordering

  // Relationships
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

model Delivery {
  id          String         @id @default(uuid()) @db.Uuid
  orderId     String         @unique @db.Uuid
  waiterId    String?        @db.Uuid
  status      DeliveryStatus @default(ASSIGNED)
  deliveredAt DateTime?      @db.Timestamptz(6)

  // Relationships
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  waiter User?  @relation(fields: [waiterId], references: [id], onDelete: SetNull)

  @@index([waiterId])
  @@index([status])
  @@map("deliveries")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  title     String   @db.VarChar(150)
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@map("notifications")
}
